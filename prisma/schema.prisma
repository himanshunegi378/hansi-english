generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum EnglishLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum QuestionType {
  COMPREHENSION
  VOCABULARY
  INFERENCE
  PERSONAL_RESPONSE
  ANALYSIS
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  stories       Story[]
}

model Story {
  id          String       @id @default(cuid())
  title       String
  content     String
  prompt      String
  level       EnglishLevel
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  createdById String
  createdBy   User         @relation(fields: [createdById], references: [id], onDelete: Cascade)
  questions   Question[]

  @@index([createdAt(sort: Desc)])
  @@index([createdById])
}

model Question {
  id            String       @id @default(cuid())
  storyId       String
  story         Story        @relation(fields: [storyId], references: [id], onDelete: Cascade)
  text          String
  type          QuestionType
  options       String[]
  correctAnswer String?
  order         Int

  @@index([storyId, order])
}

model WordMeaningCache {
  id               String   @id @default(cuid())
  lookupKey        String   @unique
  word             String
  phonetic         String?
  phonetics        Json
  hindiTranslation String?
  meanings         Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
