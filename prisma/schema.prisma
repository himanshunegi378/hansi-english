generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum EnglishLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum QuestionType {
  COMPREHENSION
  VOCABULARY
  INFERENCE
  PERSONAL_RESPONSE
  ANALYSIS
}

enum AnswerValueType {
  OPTION
  TEXT
  BOOLEAN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  stories       Story[]
  storyProgress StoryProgress[]
}

model Story {
  id          String       @id @default(cuid())
  title       String
  content     String
  prompt      String
  level       EnglishLevel
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  createdById String
  createdBy   User         @relation(fields: [createdById], references: [id], onDelete: Cascade)
  questions   Question[]
  progress    StoryProgress[]

  @@index([createdAt(sort: Desc)])
  @@index([createdById])
}

model Question {
  id            String       @id @default(cuid())
  storyId       String
  story         Story        @relation(fields: [storyId], references: [id], onDelete: Cascade)
  text          String
  type          QuestionType
  options       String[]
  correctAnswer String?
  order         Int
  answers       StoryAnswer[]

  @@index([storyId, order])
}

model StoryProgress {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  storyId        String
  story          Story         @relation(fields: [storyId], references: [id], onDelete: Cascade)
  earnedPoints   Int           @default(0)
  totalPoints    Int           @default(0)
  completedAt    DateTime?
  lastAnsweredAt DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  answers        StoryAnswer[]

  @@unique([userId, storyId])
  @@index([storyId])
}

model StoryAnswer {
  id             String          @id @default(cuid())
  progressId     String
  progress       StoryProgress   @relation(fields: [progressId], references: [id], onDelete: Cascade)
  questionId     String
  question       Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  valueType      AnswerValueType
  selectedOption String?
  textAnswer     String?
  booleanAnswer  Boolean?
  isCorrect      Boolean
  pointsEarned   Int             @default(0)
  feedback       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([progressId, questionId])
  @@index([questionId])
}

model WordMeaningCache {
  id               String   @id @default(cuid())
  lookupKey        String   @unique
  word             String
  phonetic         String?
  phonetics        Json
  hindiTranslation String?
  meanings         Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
